#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/ext_power.h>



/*
██╗      █████╗ ██╗   ██╗███████╗██████╗ ███████╗
██║     ██╔══██╗╚██╗ ██╔╝██╔════╝██╔══██╗██╔════╝
██║     ███████║ ╚████╔╝ █████╗  ██████╔╝███████╗
██║     ██╔══██║  ╚██╔╝  ██╔══╝  ██╔══██╗╚════██║
███████╗██║  ██║   ██║   ███████╗██║  ██║███████║
╚══════╝╚═╝  ╚═╝   ╚═╝   ╚══════╝╚═╝  ╚═╝╚══════╝
*/

#define EN  0
#define RU  1
#define WNDW 2
#define SYM 3
#define QWE 4
#define NAV 5
#define NUM 6
#define QNUM 7

/*
███████╗███████╗████████╗████████╗██╗███╗   ██╗ ██████╗ ███████╗
██╔════╝██╔════╝╚══██╔══╝╚══██╔══╝██║████╗  ██║██╔════╝ ██╔════╝
███████╗█████╗     ██║      ██║   ██║██╔██╗ ██║██║  ███╗███████╗
╚════██║██╔══╝     ██║      ██║   ██║██║╚██╗██║██║   ██║╚════██║
███████║███████╗   ██║      ██║   ██║██║ ╚████║╚██████╔╝███████║
╚══════╝╚══════╝   ╚═╝      ╚═╝   ╚═╝╚═╝  ╚═══╝ ╚═════╝ ╚══════╝
*/

//
// Configuring behavior of sticky shift
// to avoid double capitalised letters when rolling
//
&sk {
    quick-release;
};

/*
███╗   ███╗ █████╗  ██████╗██████╗  ██████╗ ███████╗
████╗ ████║██╔══██╗██╔════╝██╔══██╗██╔═══██╗██╔════╝
██╔████╔██║███████║██║     ██████╔╝██║   ██║███████╗
██║╚██╔╝██║██╔══██║██║     ██╔══██╗██║   ██║╚════██║
██║ ╚═╝ ██║██║  ██║╚██████╗██║  ██║╚██████╔╝███████║
╚═╝     ╚═╝╚═╝  ╚═╝ ╚═════╝╚═╝  ╚═╝ ╚═════╝ ╚══════╝
*/

/ {
    combos {

        //
        // Three buttons in the home position
        // on the left produce a combo that
        // presses command-shift-space, which
        // produces hint mode on macos via
        // an app called HomeRow
        //
        compatible = "zmk,combos";
        combo_6 {
            timeout-ms = <100>;
            key-positions = <14 15 16>;
            bindings = <&kp LG(LS(SPACE))>;
        };

        //
        // Three buttons in the home
        // position on the right produces
        // command-shift-J which turns on
        // scroll mode in HomeRow
        //
        compatible = "zmk,combos";
        combo_7 {
            timeout-ms = <100>;
            key-positions = <19 20 21>;
            bindings = <&kp LG(LS(J))>;
        };

        // (EN<->RU switch is NOT a combo — combos wouldn't fire on the thumb
        // keys. Instead, holding Super activates the QWERTY layer, whose Enter
        // key is bound to &lang_toggle. So "hold Super, tap Enter" switches.)

    };
};


/ {

        macros {

        //
        // Below two press a hotkey to switch
        // to a different layout in OS
        // and then toggle my keyboard language layer.
        //
        ZMK_MACRO(to_ru,
            wait-ms = <0>;
            bindings
                = <&kp LG(LA(N2))>
                , <&to RU>
                ;
        )

        ZMK_MACRO(to_en,
            wait-ms = <0>;
            bindings
                = <&kp LG(LA(N1))>
                , <&to EN>
                ;
        )

        //
        // Switch to the QWERTY layer with
        // Left Command / Left Option being held.
        // I'm typing in an alt layout, but
        // want my hotkeys to still be as if
        // I'm pressing them in QWERTY.
        //
        ZMK_MACRO(cmd_qwerty,
            wait-ms = <0>;
            bindings
                = <&macro_press &mo QWE &kp LCMD>
                , <&macro_pause_for_release>
                , <&macro_release &mo QWE &kp LCMD>
                ;
        )

        ZMK_MACRO(alt_qwerty,
            wait-ms = <0>;
            bindings
                = <&macro_press &mo QWE &kp LALT>
                , <&macro_pause_for_release>
                , <&macro_release &mo QWE &kp LALT>
                ;
        )
        //
        // Switch to layers while
        // switching languages for
        // the duration of the layer. Lets me
        // get symbols from the Latin layer
        // while being in the Russian layout.
        //
        ZMK_MACRO(en_sym_r,
            wait-ms = <0>;
            tap-ms = <0>;
            bindings
                = <&macro_press &mo SYM>
                , <&macro_tap &kp LG(LA(N1))>
                , <&macro_pause_for_release>
                , <&macro_tap &kp LG(LA(N2))>
                , <&macro_release &mo SYM>
                ;
        )

        //
        // Convenience macros:
        // switching tabs left and right
        //
        ZMK_MACRO(tab_l,
            wait-ms = <0>;
            tap-ms = <0>;
            bindings
                = <&macro_tap &kp LG(LS(LBKT))>
                ;
        )
        ZMK_MACRO(tab_r,
            wait-ms = <0>;
            tap-ms = <0>;
            bindings
                = <&macro_tap &kp LG(LS(RBKT))>
                ;
        )

        //
        // '#' is not on the Russian (ЙЦУКЕН) layout, so on the RU layer this
        // key briefly switches the OS to English (Cmd+Alt+1), types #, and
        // switches back to Russian (Cmd+Alt+2). wait-ms gives the OS time to
        // actually change input source between steps (tune if # or the switch
        // is unreliable).
        //
        ZMK_MACRO(ru_hash,
            wait-ms = <30>;
            tap-ms = <0>;
            bindings
                = <&macro_tap &kp LG(LA(N1))>
                , <&macro_tap &kp HASH>
                , <&macro_tap &kp LG(LA(N2))>
                ;
        )

        //
        // EN<->RU switch, bound to Enter on the QWERTY layer (which you reach
        // by holding Super). Cmd+Space toggles the macOS input source; &tog RU
        // toggles the keyboard's Russian layer — both directions, one key.
        //
        ZMK_MACRO(lang_toggle,
            wait-ms = <0>;
            tap-ms = <0>;
            bindings
                = <&kp LG(SPACE)>
                , <&tog RU>
                ;
        )
    };






/*
██████╗ ███████╗██╗  ██╗ █████╗ ██╗   ██╗██╗ ██████╗ ██╗   ██╗██████╗ ███████╗
██╔══██╗██╔════╝██║  ██║██╔══██╗██║   ██║██║██╔═══██╗██║   ██║██╔══██╗██╔════╝
██████╔╝█████╗  ███████║███████║██║   ██║██║██║   ██║██║   ██║██████╔╝███████╗
██╔══██╗██╔══╝  ██╔══██║██╔══██║╚██╗ ██╔╝██║██║   ██║██║   ██║██╔══██╗╚════██║
██████╔╝███████╗██║  ██║██║  ██║ ╚████╔╝ ██║╚██████╔╝╚██████╔╝██║  ██║███████║
╚═════╝ ╚══════╝╚═╝  ╚═╝╚═╝  ╚═╝  ╚═══╝  ╚═╝ ╚═════╝  ╚═════╝ ╚═╝  ╚═╝╚══════╝
*/
        behaviors {
        //
        // Custom Layer-Tap: switches to layer when held,
        // presses a button when pressed. ZMK has this
        // by default (called &lt), but I duplicate it
        // because I want to play with tapping terms and such.
        //
        lt_cust: lt_cust {
            compatible = "zmk,behavior-hold-tap";
            label="LT_CUSTOM";
            #binding-cells = <2>;
            flavor = "hold-preferred";
            tapping-term-ms = <250>;
            quick-tap-ms = <125>;
            bindings = <&mo>, <&kp>;
        };

        //
        // Same as lt_cust, but calls macros when held.
        // I use this to switch between languages. I wrote
        // language-switching macros that (a) switch my active
        // layer; (b) switch the OS language.
        //
        hold_ru: hold_ru {
            compatible = "zmk,behavior-hold-tap";
            label="hold_ru";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <250>;
            quick-tap-ms = <125>;
            bindings = <&to_ru>, <&kp>;
        };

        hold_en: hold_en {
            compatible = "zmk,behavior-hold-tap";
            label="hold_en";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <250>;
            quick-tap-ms = <125>;
            bindings = <&to_en>, <&kp>;
        };

        hold_sym_r: hold_sym_r {
            compatible = "zmk,behavior-hold-tap";
            label="hold_sym_r";
            #binding-cells = <2>;
            flavor = "hold-preferred";
            tapping-term-ms = <250>;
            quick-tap-ms = <125>;
            bindings = <&en_sym_r>, <&kp>;
        };

	//
	// This will make shift
	// toggle to nav layer when held down
	// and tap dance when tapped.
	//
        sd_tog: behavior_sd_tog {
            compatible = "zmk,behavior-hold-tap";
            label = "sd_tog";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <200>;
            bindings = <&mo>, <&sk>;
        };

	//
	// This is a sticky shift that, when pressed two times
	// quickly, becomes a caps shift.
	//
        sd: sd {
            compatible = "zmk,behavior-tap-dance";
            label = "SD";
            #binding-cells = <0>;
            tapping-term-ms = <200>;
            bindings = <&sd_tog WNDW LSHFT>, <&caps_word>;
        };

	//
	// This will make a layer
	// toggle when pressed and
	// activate when held
	//
        mo_tog: behavior_mo_tog {
            compatible = "zmk,behavior-hold-tap";
            label = "mo_tog";
            #binding-cells = <2>;
            flavor = "hold-preferred";
            tapping-term-ms = <200>;
            bindings = <&mo>, <&tog>;
        };

        //
        // Russian double-tap keys. Single tap = the primary Cyrillic letter,
        // double tap = the paired letter. Keycodes are the QWERTY positions
        // that the macOS Russian (ЙЦУКЕН) layout maps to each Cyrillic letter,
        // e.g. tapping &kp I under ЙЦУКЕН produces ш.
        //   ru_w: ш / щ   (I / O)
        //   ru_e: е / э   (T / ')
        //   ru_u: у / ю   (E / .)
        //   ru_i: и / й   (B / Q)
        //   ru_o: о / ё   (J / `)
        //   ru_j: ь / ъ   (M / ])
        //   ru_z: ж / з   (; / P)
        //
        ru_w: ru_w { compatible = "zmk,behavior-tap-dance"; label = "RU_W"; #binding-cells = <0>; tapping-term-ms = <200>; bindings = <&kp I>, <&kp O>; };
        ru_e: ru_e { compatible = "zmk,behavior-tap-dance"; label = "RU_E"; #binding-cells = <0>; tapping-term-ms = <200>; bindings = <&kp T>, <&kp APOS>; };
        ru_u: ru_u { compatible = "zmk,behavior-tap-dance"; label = "RU_U"; #binding-cells = <0>; tapping-term-ms = <200>; bindings = <&kp E>, <&kp DOT>; };
        ru_i: ru_i { compatible = "zmk,behavior-tap-dance"; label = "RU_I"; #binding-cells = <0>; tapping-term-ms = <200>; bindings = <&kp B>, <&kp Q>; };
        ru_o: ru_o { compatible = "zmk,behavior-tap-dance"; label = "RU_O"; #binding-cells = <0>; tapping-term-ms = <200>; bindings = <&kp J>, <&kp GRAVE>; };
        ru_j: ru_j { compatible = "zmk,behavior-tap-dance"; label = "RU_J"; #binding-cells = <0>; tapping-term-ms = <200>; bindings = <&kp M>, <&kp RBKT>; };
        ru_z: ru_z { compatible = "zmk,behavior-tap-dance"; label = "RU_Z"; #binding-cells = <0>; tapping-term-ms = <200>; bindings = <&kp SEMI>, <&kp P>; };

        //
        // The red key: tap = Escape, hold = Ctrl+Alt+Cmd (the "Meh" modifier,
        // combine with other keys). Used as `&red LC(LA(LGUI)) ESC`.
        // hold-preferred so the mods engage as soon as another key is pressed.
        //
        red: red {
            compatible = "zmk,behavior-hold-tap";
            label = "RED";
            #binding-cells = <2>;
            flavor = "hold-preferred";
            tapping-term-ms = <200>;
            quick-tap-ms = <125>;
            bindings = <&kp>, <&kp>;
        };

    };



/*
██╗      █████╗ ██╗   ██╗███████╗██████╗ ███████╗
██║     ██╔══██╗╚██╗ ██╔╝██╔════╝██╔══██╗██╔════╝
██║     ███████║ ╚████╔╝ █████╗  ██████╔╝███████╗
██║     ██╔══██║  ╚██╔╝  ██╔══╝  ██╔══██╗╚════██║
███████╗██║  ██║   ██║   ███████╗██║  ██║███████║
╚══════╝╚═╝  ╚═╝   ╚═╝   ╚══════╝╚═╝  ╚═╝╚══════╝
*/

        keymap {
                compatible = "zmk,keymap";
                default_layer {
/*
┌───────┬───────┬───────┬───────┬───────┬───────┐                        ┌───────┬───────┬───────┬───────┬───────┬───────┐
│       │       │       │       │       │       │░                       │       │       │       │       │       │       │░
│  tab  │   B   │   Y   │   O   │   U   │   !   │░                       │   ?   │   L   │   D   │   W   │   Z   │       │░
│       │       │       │       │       │       │░                       │       │       │       │       │       │       │░
├───────┼───────┼───────┼───────┼───────┼───────┤░                       ├───────┼───────┼───────┼───────┼───────┼───────┤░
│  caps │       │       │       │       │       │░                       │       │       │       │       │       │  RUS  │░
│  ---  │   C   │   I   │   E   │   A   │   .   │░                       │   V   │   H   │   T   │   S   │   N   │  ---  │░
│  esc  │       │       │       │       │       │░                       │       │       │       │       │       │   Q   │░
├───────┼───────┼───────┼───────┼───────┼───────┤░                       ├───────┼───────┼───────┼───────┼───────┼───────┤░
│ stick │       │       │       │       │       │░                       │       │       │       │       │       │ stick │░
│ shift │   G   │   X   │   J   │   K   │   ,   │░                       │   #   │   R   │   M   │   F   │   P   │ shift │░
│       │       │       │       │       │       │░                       │       │       │       │       │       │       │░
└───────┴───────┴───────┴───────┴───────┴───────┘░                       └───────┴───────┴───────┴───────┴───────┴───────┘░
 ░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░┌───────┐      ┌───────┐ ░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
                                ┌───────┬───────┐│       │░     │       │░┌───────┬───────┐
                                │       │       ││  SYM  │░     │       │░│       │       │░
                                │   ⌥   │   ⌘   ││  ---  │░     │ bkspc │░│  NAV  │  NUM  │░
                                │       │       ││ space │░     │       │░│       │       │░
                                └───────┴───────┘│       │░     │       │░└───────┴───────┘░
                                 ░░░░░░░░░░░░░░░░│       │░     │       │░ ░░░░░░░░░░░░░░░░░
                                                 └───────┘░     └───────┘░
                                                  ░░░░░░░░░      ░░░░░░░░░
*/


                        bindings = <

   &kp TAB              &kp B  &kp Y  &kp O  &kp U  &kp EXCL                                &kp QMARK  &kp L  &kp D  &kp W  &kp Z  &none
   &red LC(LA(LGUI)) ESC &kp C  &kp I  &kp E  &kp A  &kp DOT                                &kp V      &kp H  &kp T  &kp S  &kp N  &hold_ru 0 Q
   &sd_tog WNDW LSHIFT  &kp G  &kp X  &kp J  &kp K  &kp COMMA                               &kp HASH   &kp R  &kp M  &kp F  &kp P  &sd

                  &alt_qwerty  &cmd_qwerty  &lt_cust SYM SPACE             &kp BSPC  &mo NAV  &mo NUM
                        >;
                };






                    russian_layer {
/*
Cyrillic letters sit where the matching LATIN logical key is on the EN layer
(e.g. п is where Latin p is). Keycodes sent are the QWERTY positions the macOS
Russian (ЙЦУКЕН) layout maps to each letter. (x) below a key = its double-tap.

Inner columns carry always-on punctuation. In Russian mode these use ЙЦУКЕН
keycodes: ! = Shift+1, . = "/" key, , = Shift+"/", ? = Shift+7. # is not on
ЙЦУКЕН, so it uses the ru_hash macro (switch to EN, type #, switch back).

